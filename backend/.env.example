# Backend — variáveis de ambiente (copie para .env; NÃO versionar)

# Banco (Postgres + PostGIS) — ver docker-compose.dev.yml (isolamento dev/prod, D1)
DATABASE_URL=postgres://rota33:rota33_dev@localhost:5442/rota33_dev

# Servidor
PORT=3100
NODE_ENV=development
TZ=America/Sao_Paulo

# Auth / sessão (Sprint 2)
JWT_ACCESS_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# Providers (sprints correspondentes)
GEOCODING_PROVIDER=          # nominatim | google
OSRM_URL=
GOOGLE_MAPS_API_KEY=
GOOGLE_VISION_CREDENTIALS=   # OCR (Sprint 4)
VOICE_PROVIDER=              # a definir (Sprint 5)
PAYMENT_PROVIDER=            # stripe | paypal | mercadopago (Sprint 10)
AD_PROVIDER=                 # admob | meta | ... (Sprint 10)
